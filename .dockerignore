# Keep Docker build context small and reproducible.

.git
.github
.cache
.crest-local
.local
.idea
.vscode
.DS_Store
reports
private
private-tests
secrets
tmp
temp
.tmp
.temp

node_modules
**/node_modules
runtime
extensions
config
docs
installer
scripts
sdk
**/.flattened-pom.xml
**/.stylelintcache
**/components.d.ts

# Images are built from pre-generated frontend/backend artifacts.
core/*
!core/core-frontend
core/core-frontend/*
!core/core-frontend/dist
!core/core-frontend/dist/**
!core/core-backend
core/core-backend/*
!core/core-backend/target
core/core-backend/target/*
!core/core-backend/target/CoreApplication.jar

# Build output is ignored by default; the final backend jar is copied into the image.
**/target
!core/core-backend/target
!core/core-backend/target/CoreApplication.jar

# Only the fork-managed OceanBase driver is packaged from this repository.
drivers/*.jar
!drivers/oceanbase-client-2.4.17.jar

*.log
*.pid
*.tmp
*.bak
*.tar
*.tar.gz
*.zip
*.rar
