# Copy this file to a private location such as .local/crest-production.env.
# Do not commit real values.

export CREST_PRODUCTION_HOST='crest.example.com'
export CREST_ORIGIN_LIST='https://crest.example.com'
export CREST_INGRESS_CLASS_NAME='nginx'

export CREST_DB_HOST='obproxy.example.internal'
export CREST_DB_PORT='2883'
export CREST_DB_USERNAME='<user>@<tenant>#<cluster>'
export CREST_DB_PASSWORD='<long-random-db-password>'

export CREST_AES_KEY='<32-character-random-aes-key>'
export CREST_AES_IV='<16-character-iv>'
export CREST_INITIAL_PASSWORD='<long-random-admin-password>'
export CREST_TOKEN_SECRET='<at-least-32-character-token-secret>'

export CREST_REDIS_CLUSTER_NODES='redis-a:6379,redis-b:6379,redis-c:6379'
export CREST_REDIS_USERNAME='ops01-prod-crest-core-acl'
export CREST_REDIS_PASSWORD='<long-random-redis-password>'
export CREST_REDIS_KEY_PREFIX='{<org>-<env>-crest-core}:prod'
export CREST_REDIS_SSL_ENABLED='false'

export CREST_PROMETHEUS_ENABLED='false'
# Required when CREST_PROMETHEUS_ENABLED=true.
# export CREST_PROMETHEUS_TOKEN='<at-least-32-character-prometheus-token>'

export CREST_BACKEND_IMAGE='ghcr.io/sevoniva/crest-service:v1.0.0'
export CREST_FRONTEND_IMAGE='ghcr.io/sevoniva/crest-web:v1.0.0'

export CREST_DATA_STORAGE_CLASS='<rwx-storage-class>'
export CREST_DATA_STORAGE_SIZE='50Gi'
