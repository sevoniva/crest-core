  "scripts": {
    "dev:win": "set NODE_OPTIONS=--max_old_space_size=4096 && vite --mode dev --host 0.0.0.0",
    "dev": "NODE_OPTIONS=--max_old_space_size=4096 vite --mode dev --host 0.0.0.0",
    "dev:fast": "CREST_SKIP_VITE_LINT=true NODE_OPTIONS=--max_old_space_size=4096 vite --mode dev --host 0.0.0.0",
    "build:flush": "cd ./flushbonading && rimraf ./demo.html && node ./index.js",
    "ts:check": "vue-tsc --noEmit",
    "build:base": "CREST_SKIP_VITE_LINT=true NODE_OPTIONS=--max_old_space_size=4096 vite build --logLevel warn --mode base && pnpm run build:flush",
    "build:base:gzip": "CREST_SKIP_VITE_LINT=true CREST_ENABLE_VITE_GZIP=true NODE_OPTIONS=--max_old_space_size=4096 vite build --logLevel warn --mode base && pnpm run build:flush",
    "build:base:strict": "NODE_OPTIONS=--max_old_space_size=4096 vite build --logLevel warn --mode base && pnpm run build:flush",
    "build:lite:check": "node ./scripts/check-lite-build.mjs",
    "build:lib": "vite build --mode lib",
    "lint": "eslint . --ext .vue,.js,.ts,.jsx,.tsx --fix",
    "lint:check": "eslint . --ext .vue,.js,.ts,.jsx,.tsx",
    "lint:stylelint": "stylelint --fix \"**/*.{vue,less,postcss,css,scss}\" --cache --cache-location node_modules/.cache/stylelint/",
    "preview": "vite preview"
  },
